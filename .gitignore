# Environment — NEVER commit these
.env
.env.local
.env.production

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.venv/
*.egg-info/
dist/
build/

# Models — large files, download separately
backend/models/*.pt
backend/models/*.onnx
